--- a/tools/ios_framework_prepare.sh
+++ b/tools/ios_framework_prepare.sh
@@ -18,7 +18,6 @@ XCODE_PROJECT_PATH='tools/ios-framework/NodeMobile.xcodeproj/project.pbxproj'
 
 declare -a outputs_common=(
     "libada.a"
-    "libbase64.a"
     "libbrotli.a"
     "libcares.a"
     "libgtest_main.a"
@@ -28,17 +27,24 @@ declare -a outputs_common=(
     "libnghttp2.a"
     "libnghttp3.a"
     "libngtcp2.a"
+    "libnbytes.a"
+    "libncrypto.a"
     "libnode.a"
     "libopenssl.a"
+    "libsimdjson.a"
     "libsimdutf.a"
+    "libsqlite.a"
     "libuv.a"
     "libuvwasi.a"
+    "libv8_abseil.a"
     "libv8_base_without_compiler.a"
     "libv8_compiler.a"
     "libv8_initializers.a"
+    "libv8_initializers_slow.a"
     "libv8_libbase.a"
     "libv8_libplatform.a"
     "libv8_snapshot.a"
+    "libv8_turboshaft.a"
     "libv8_zlib.a"
     "libzlib.a"
 )
@@ -50,13 +56,71 @@ declare -a outputs_x64_only=(
     "libbase64_ssse3.a"
 )
 declare -a outputs_arm64_only=(
-    "libbase64_neon64.a"
     "libzlib_inflate_chunk_simd.a"
 )
 
+# The iOS framework project still references libraries removed after Node 18.
+# Strip those references before Xcode evaluates the Frameworks build phase.
+declare -a outputs_removed_common=(
+    "libbase64.a"
+)
+declare -a outputs_removed_arm64=(
+    "libbase64_neon64.a"
+)
+
+# These Node 22 archives are not represented by the legacy Xcode project.
+# Pass them to the linker explicitly until the upstream project is regenerated.
+declare -a outputs_node22_extra=(
+    "libnbytes.a"
+    "libncrypto.a"
+    "libsimdjson.a"
+    "libsqlite.a"
+    "libv8_abseil.a"
+    "libv8_initializers_slow.a"
+    "libv8_turboshaft.a"
+)
+
 declare -a outputs_x64=("${outputs_common[@]}" "${outputs_x64_only[@]}")
 declare -a outputs_arm64=("${outputs_common[@]}" "${outputs_arm64_only[@]}")
 
+node22_extra_linker_flags() {
+  local library_root
+  local linker_flags="-all_load -v -lc++"
+  library_root="$(cd "$TARGET_LIBRARY_PATH" && pwd)"
+  for output_file in "${outputs_node22_extra[@]}"; do
+    linker_flags+=" ${library_root}/${output_file}"
+  done
+  printf '%s' "$linker_flags"
+}
+
+stage_static_libraries() {
+  local destination="$1"
+  shift
+  local library_root
+  library_root="$(cd "$LIBRARY_PATH" && pwd)"
+  mkdir -p "$destination"
+
+  for output_file in "$@"; do
+    if [[ ! -f "${library_root}/${output_file}" ]]; then
+      echo "Missing static library: ${library_root}/${output_file}" >&2
+      return 1
+    fi
+    # A hard link keeps the archive alive across `make clean` without
+    # duplicating its (often multi-gigabyte) contents on the runner disk.
+    ln -f "${library_root}/${output_file}" "${destination}/${output_file}"
+  done
+}
+
+prune_build_intermediates() {
+  # The framework link consumes the root-level archives, not their object
+  # directories. Removing those objects leaves enough room for Xcode's link.
+  rm -rf \
+    "${LIBRARY_PATH}/obj.host" \
+    "${LIBRARY_PATH}/obj.target" \
+    "${LIBRARY_PATH}/.deps"
+  df -h /
+}
+
 build_for_arm64_device() {
   make clean
   GYP_DEFINES="target_arch=arm64 host_os=mac target_os=ios"
@@ -74,6 +138,4 @@ build_for_arm64_device() {
-  # Move compilation outputs
-  mkdir -p $TARGET_LIBRARY_PATH/arm64-device
-  for output_file in "${outputs_arm64[@]}"; do
-    cp $LIBRARY_PATH/$output_file $TARGET_LIBRARY_PATH/arm64-device/
-  done
+  # Stage compilation outputs without duplicating the large archives.
+  stage_static_libraries "$TARGET_LIBRARY_PATH/arm64-device" "${outputs_arm64[@]}"
+  prune_build_intermediates
 }
@@ -100,6 +162,4 @@ build_for_arm64_simulator() {
-  # Move compilation outputs
-  mkdir -p $TARGET_LIBRARY_PATH/arm64-simulator
-  for output_file in "${outputs_arm64[@]}"; do
-      cp $LIBRARY_PATH/$output_file $TARGET_LIBRARY_PATH/arm64-simulator/
-  done
+  # Stage compilation outputs without duplicating the large archives.
+  stage_static_libraries "$TARGET_LIBRARY_PATH/arm64-simulator" "${outputs_arm64[@]}"
+  prune_build_intermediates
 }
@@ -123,6 +183,4 @@ build_for_x64_simulator() {
-  # Move compilation outputs
-  mkdir -p $TARGET_LIBRARY_PATH/x64-simulator
-  for output_file in "${outputs_x64[@]}"; do
-    cp $LIBRARY_PATH/$output_file $TARGET_LIBRARY_PATH/x64-simulator/
-  done
+  # Stage compilation outputs without duplicating the large archives.
+  stage_static_libraries "$TARGET_LIBRARY_PATH/x64-simulator" "${outputs_x64[@]}"
+  prune_build_intermediates
 }
@@ -135,6 +193,9 @@ build_framework_for_arm64_device() {
   done
   # Remove libraries that do not exist for this target
   cp $XCODE_PROJECT_PATH $XCODE_PROJECT_PATH.bak
+  for output_file in "${outputs_removed_common[@]}" "${outputs_removed_arm64[@]}"; do
+    grep -vF "$output_file" $XCODE_PROJECT_PATH > temp && mv temp $XCODE_PROJECT_PATH
+  done
   for output_file in "${outputs_x64_only[@]}"; do
     grep -vF "$output_file" $XCODE_PROJECT_PATH > temp && mv temp $XCODE_PROJECT_PATH
   done
@@ -145,7 +206,8 @@ build_framework_for_arm64_device() {
     -configuration Release \
     -arch arm64 \
     -sdk "iphoneos" \
-    SYMROOT=$FRAMEWORK_TARGET_DIR/iphoneos-arm64
+    SYMROOT=$FRAMEWORK_TARGET_DIR/iphoneos-arm64 \
+    OTHER_LDFLAGS="$(node22_extra_linker_flags)"
   mv $XCODE_PROJECT_PATH.bak $XCODE_PROJECT_PATH
 }
 
@@ -157,6 +219,9 @@ build_framework_for_arm64_simulator() {
   done
   # Remove libraries that do not exist for this target
   cp $XCODE_PROJECT_PATH $XCODE_PROJECT_PATH.bak
+  for output_file in "${outputs_removed_common[@]}" "${outputs_removed_arm64[@]}"; do
+    grep -vF "$output_file" $XCODE_PROJECT_PATH > temp && mv temp $XCODE_PROJECT_PATH
+  done
   for output_file in "${outputs_x64_only[@]}"; do
     grep -vF "$output_file" $XCODE_PROJECT_PATH > temp && mv temp $XCODE_PROJECT_PATH
   done
@@ -167,7 +232,8 @@ build_framework_for_arm64_simulator() {
     -configuration Release \
     -arch arm64 \
     -sdk "iphonesimulator" \
-    SYMROOT=$FRAMEWORK_TARGET_DIR/iphonesimulator-arm64
+    SYMROOT=$FRAMEWORK_TARGET_DIR/iphonesimulator-arm64 \
+    OTHER_LDFLAGS="$(node22_extra_linker_flags)"
   mv $XCODE_PROJECT_PATH.bak $XCODE_PROJECT_PATH
 }
 
@@ -179,6 +245,9 @@ build_framework_for_x64_simulator() {
   done
   # Remove libraries that do not exist for this target
   cp $XCODE_PROJECT_PATH $XCODE_PROJECT_PATH.bak
+  for output_file in "${outputs_removed_common[@]}"; do
+    grep -vF "$output_file" $XCODE_PROJECT_PATH > temp && mv temp $XCODE_PROJECT_PATH
+  done
   for output_file in "${outputs_arm64_only[@]}"; do
     grep -vF "$output_file" $XCODE_PROJECT_PATH > temp && mv temp $XCODE_PROJECT_PATH
   done
@@ -189,6 +258,7 @@ build_framework_for_x64_simulator() {
     -configuration Release \
     -arch x86_64 \
     -sdk "iphonesimulator" \
-    SYMROOT=$FRAMEWORK_TARGET_DIR/iphonesimulator-x64
+    SYMROOT=$FRAMEWORK_TARGET_DIR/iphonesimulator-x64 \
