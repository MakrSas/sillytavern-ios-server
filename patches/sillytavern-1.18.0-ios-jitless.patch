+
+/**
+ * WebAssembly is unavailable in the iOS jitless runtime. This reversible byte
+ * tokenizer keeps prompt estimation and chunk previews operational without
+ * loading tiktoken's WASM module. Its IDs are local estimates, not model IDs.
+ */
+function createPortableTokenizer() {
+    return {
+        encode(text) {
+            const bytes = Buffer.from(String(text), 'utf8');
+            const ids = [];
+            for (let index = 0; index < bytes.length; index += 3) {
+                const length = Math.min(3, bytes.length - index);
+                const first = bytes[index] ?? 0;
+                const second = bytes[index + 1] ?? 0;
+                const third = bytes[index + 2] ?? 0;
+                ids.push((
+                    (length << 24)
+                    | (first << 16)
+                    | (second << 8)
+                    | third
+                ) >>> 0);
+            }
+            return Uint32Array.from(ids);
+        },
+        decode(ids) {
+            const bytes = [];
+            for (const rawId of ids) {
+                const id = Number(rawId) >>> 0;
+                const length = Math.min(3, id >>> 24);
+                if (length >= 1) bytes.push((id >>> 16) & 0xff);
+                if (length >= 2) bytes.push((id >>> 8) & 0xff);
+                if (length >= 3) bytes.push(id & 0xff);
+            }
+            return Uint8Array.from(bytes);
+        },
+    };
+}
 
