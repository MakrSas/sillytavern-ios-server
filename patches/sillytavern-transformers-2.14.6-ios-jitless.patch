+    [0xFFF9, 0xFFFB], [0xF0000, 0xFFFFD], [0x100000, 0x10FFFD],
+];
+
+function isControlCodePoint(codePoint) {
+    return CONTROL_CODE_POINT_RANGES.some(([start, end]) => codePoint >= start && codePoint <= end);
